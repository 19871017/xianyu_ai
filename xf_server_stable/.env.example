# 闲鱼AI助手服务端 - 安全配置示例
# 复制为 /opt/xf_server/.env 并填入随机强值（部署脚本会自动加载）。
# 生成随机串： python3 -c "import secrets;print(secrets.token_urlsafe(48))"

# 运行模式：production 时缺失关键密钥会打印告警
XF_ENV=production

# JWT 签名密钥（务必随机、保密；泄露=可伪造管理员令牌）
JWT_SECRET_KEY=

# 管理员登录密码（强口令）。首次轮换线上 admin123 时同时设置：
#   ADMIN_FORCE_RESET=1   轮换成功后可移除该行
ADMIN_PASSWORD=
ADMIN_FORCE_RESET=0

# 客户端调用密钥（activate/verify/heartbeat 需携带 X-Client-Key）
# 全部客户端升级并内置该 Key 后，再把 REQUIRE_CLIENT_KEY 置 1 强制校验
CLIENT_API_KEY=
REQUIRE_CLIENT_KEY=0

# 设备/心跳控制（秒）
HEARTBEAT_INTERVAL_SECONDS=60
OFFLINE_THRESHOLD_SECONDS=180
REQUEST_TIMESTAMP_WINDOW_SECONDS=300

# 每个 License 默认最大绑定设备数
MAX_DEVICES_PER_LICENSE=3

# 跨域来源（默认同源，不放开）。如管理后台独立域名，按需逗号分隔填写
CORS_ORIGINS=
